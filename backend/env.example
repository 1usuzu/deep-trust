# ============================================================
# DeepTrust Backend (Core API) — Environment Variables
# ============================================================
#
# IMPORTANT
# - Do NOT commit real secrets. Copy this file to `backend/.env` on your server.
# - `backend/api.py` loads `backend/.env` automatically (simple loader).
#

# --- Required: signing key for Oracle / server signatures (Ethereum private key) ---
# Use a dedicated key for this project.
SERVER_PRIVATE_KEY=

# --- Dev-only fallback (NOT for production) ---
ALLOW_INSECURE_DEV_KEY=false
INSECURE_DEV_PRIVATE_KEY=

# --- CORS ---
# Comma-separated list. Use "*" only in dev.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional: Consumer API key gate ---
# If empty, consumer endpoints are open (dev mode).
# Example usage: API_KEYS=dev-key-local,another-key
API_KEYS=dev-key-local

# --- Optional: thresholds (if you also tune policy in consumer_api.py) ---
APPROVAL_THRESHOLD=0.75
REVIEW_THRESHOLD=0.55

# --- Blockchain RPC / Contract ---
# Example local hardhat node: http://127.0.0.1:8545 (chainId 31337)
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CONTRACT_ADDRESS=

