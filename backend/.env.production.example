# --- DeepTrust V1: Production Environment (Backend) ---

# [IMPORTANT] Đổi tên file này thành .env trên server Render
# [WARNING] Không chia sẻ các giá trị này công khai

# 1. Oracle Security
# Private key của tài khoản làm Oracle ký xác thực
SERVER_PRIVATE_KEY=your_production_oracle_private_key

# Tắt chế độ không an toàn trong production
ALLOW_INSECURE_DEV_KEY=false

# 2. CORS (Cho phép Frontend gọi API)
# URL của Frontend trên Vercel (không có gạch chéo cuối)
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# 3. Blockchain Config (Mạng thật/Testnet)
RPC_URL=https://rpc-amoy.polygon.technology/
CHAIN_ID=80002
CONTRACT_ADDRESS=0x_your_verification_contract_address
