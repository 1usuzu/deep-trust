# REQUIRED for app startup (including /api/health):
# - Use a real private key in production.
# - Never commit actual secret values.
SERVER_PRIVATE_KEY=0x_your_oracle_private_key

# DEV ONLY fallback: if true and SERVER_PRIVATE_KEY is empty,
# backend will use INSECURE_DEV_PRIVATE_KEY instead.
ALLOW_INSECURE_DEV_KEY=false
INSECURE_DEV_PRIVATE_KEY=

# Optional: CORS allowlist (comma-separated). Defaults to localhost frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional blockchain writer config (required only for /api/blockchain/record)
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CONTRACT_ADDRESS=0x_your_contract_address
