# Oracle Signer Private Key (KEEP SECRET!)
# Development: copy key from Hardhat node output when running local
# Production: generate dedicated key and add issuer address in contract
SERVER_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Local-only shortcut: set true to use hardhat account #0 fallback key
ALLOW_INSECURE_DEV_KEY=false
INSECURE_DEV_PRIVATE_KEY=

# Optional: CORS allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
