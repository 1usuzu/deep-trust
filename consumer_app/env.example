# ============================================================
# DeepTrust Consumer App — Environment Variables
# ============================================================

# URL của Core API backend
VERIFICATION_API_URL=http://127.0.0.1:8000

# API Key để gọi /v1/consumer/ endpoints (phải khớp với API_KEYS trong backend)
API_KEY=dev-key-local

# Policy thresholds (nên khớp với backend)
APPROVAL_THRESHOLD=0.75
REVIEW_THRESHOLD=0.55

# Tên hiển thị cho portal
APP_TITLE=DeepTrust.AI — Cổng xác thực (Consumer Portal)
